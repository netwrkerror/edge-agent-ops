{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["edgeops"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "edge agent ops — guardrails",
  "uid": "edgeops",
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "title": "fleet healthy",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "edgeops-prom" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "description": "current count of healthy devices; dips while a fault is active, recovers after remediation",
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "max": 4,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 12,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "edgeops-prom" },
          "expr": "edgeops_fleet_healthy",
          "refId": "A",
          "legendFormat": "healthy devices"
        }
      ]
    },
    {
      "id": 2,
      "title": "remediation outcomes over time",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "edgeops-prom" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "description": "per-result remediation rate (success | denied | rolled_back | declined | no_diagnosis)",
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "stacking": { "mode": "none" }
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "success" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ] },
          { "matcher": { "id": "byName", "options": "denied" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] },
          { "matcher": { "id": "byName", "options": "rolled_back" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } } ] },
          { "matcher": { "id": "byName", "options": "declined" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } } ] }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "edgeops-prom" },
          "expr": "sum by (result) (rate(edgeops_remediations_total[1m]))",
          "refId": "A",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "denial + rollback rate (the guardrail story)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "edgeops-prom" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "description": "actions the policy blocked (denied) and fixes that failed verification and were rolled back",
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never"
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "denied" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] },
          { "matcher": { "id": "byName", "options": "rolled back" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } } ] }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "edgeops-prom" },
          "expr": "rate(edgeops_remediations_total{result=\"denied\"}[1m])",
          "refId": "A",
          "legendFormat": "denied"
        },
        {
          "datasource": { "type": "prometheus", "uid": "edgeops-prom" },
          "expr": "rate(edgeops_remediations_total{result=\"rolled_back\"}[1m])",
          "refId": "B",
          "legendFormat": "rolled back"
        }
      ]
    },
    {
      "id": 4,
      "title": "approval holds",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "edgeops-prom" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "description": "rate of high-risk actions that hit NEEDS_APPROVAL and were held for a human",
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never",
            "gradientMode": "opacity"
          },
          "color": { "mode": "fixed", "fixedColor": "yellow" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "edgeops-prom" },
          "expr": "rate(edgeops_approval_holds_total[1m])",
          "refId": "A",
          "legendFormat": "approval holds / s"
        }
      ]
    },
    {
      "id": 5,
      "title": "decision latency (p50 / p95)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "edgeops-prom" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "description": "per-decision wall-clock time; tiny for the mock brain, seconds for a local LLM",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "edgeops-prom" },
          "expr": "histogram_quantile(0.5, sum by (le) (rate(edgeops_decision_latency_seconds_bucket[5m])))",
          "refId": "A",
          "legendFormat": "p50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "edgeops-prom" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(edgeops_decision_latency_seconds_bucket[5m])))",
          "refId": "B",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 6,
      "title": "eval scores (static with mock brain)",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "edgeops-prom" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "description": "latest eval rates by dimension in [0, 1]; flat unless a real model is scored",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.5 },
              { "color": "green", "value": 0.9 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": true,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "edgeops-prom" },
          "expr": "edgeops_eval_score",
          "refId": "A",
          "legendFormat": "{{dimension}}",
          "instant": true
        }
      ]
    }
  ]
}
